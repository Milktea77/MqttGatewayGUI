<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss} [%t] %-5level - %msg%n"/>
        </Console>

        <RollingFile name="FileAppender" fileName="logs/mqtt_transform.log"
                     filePattern="logs/mqtt_transform-%d{yyyy-MM-dd}.log">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%t] %-5level %logger{36} - %msg%n"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
            </Policies>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="FileAppender">
                <Filters>
                    <ThresholdFilter level="INFO" onMatch="NEUTRAL" onMismatch="DENY"/>
                    <ThreadContextMapFilter onMatch="ACCEPT" onMismatch="NEUTRAL">
                    </ThreadContextMapFilter>
                </Filters>
            </AppenderRef>
        </Root>
    </Loggers>
</Configuration>